{
  "name": "@nandalalshukla/auth-hero",
  "version": "1.0.2",
  "description": "A complete, secure, production-ready authentication server with email/password, OAuth, MFA (TOTP), session management, and more.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      }
    }
  },
  "files": [
    "dist",
    "prisma/schema.prisma",
    "prisma/migrations",
    ".env.example"
  ],
  "license": "MIT",
  "author": "Nandalal Shukla",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "authentication",
    "auth",
    "oauth",
    "mfa",
    "totp",
    "session",
    "express",
    "prisma",
    "security",
    "login",
    "register",
    "jwt",
    "2fa"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/pino": "^7.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "prepublishOnly": "npm run build",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "argon2": "^0.44.0",
    "authhero": ".",
    "axios": "^1.13.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "otplib": "^13.3.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  }
}
