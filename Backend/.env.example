# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/authhero

# ─── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
VERIFY_EMAIL_TOKEN_SECRET=
FORGOT_PSWD_TOKEN_SECRET=
RESET_PSWD_TOKEN_SECRET=

# ─── MFA ───────────────────────────────────────────────────────────────────────
# 64-char hex string (32 bytes) for AES-256-GCM encryption of TOTP secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=
MFA_TEMP_TOKEN_SECRET=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ─── Frontend URLs ─────────────────────────────────────────────────────────────
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ─── OAuth Providers (optional — only configure if you use them) ───────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/oauth/callback/google

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5000/auth/oauth/callback/github

# Facebook: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/auth/oauth/callback/facebook
